{
  "name": "vyrva-sound-engineer",
  "version": "1.0.0",
  "description": "Vyrva Sound Engineer HTML template",
  "scripts": {
    "build": "sass src/scss/main.scss dist/css/main.css --style=compressed --no-source-map",
    "build:dev": "sass src/scss/main.scss dist/css/main.css --style=expanded",
    "watch": "sass src/scss/main.scss dist/css/main.css --style=expanded --watch"
  },
  "devDependencies": {
    "sass": "^1.72.0"
  }
}
